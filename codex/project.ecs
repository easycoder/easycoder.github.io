!  Standalone launcher for EasyCoder Codex

	script CodexHost

	div Root
	div Panel
	span Title
	span Message
	button StartButton
	module CodexModule
	variable Script
	variable Running
	variable Incoming

	create Root
	set the style of Root to `width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-family:sans-serif`

	create Panel in Root
	set the style of Panel to `max-width:40em;border:1px solid #cccccc;border-radius:0.8em;padding:1.2em;background:#f9f9f9`

	create Title in Panel
	set the content of Title to `EasyCoder Codex`
	set the style of Title to `display:block;font-size:1.3em;font-weight:700;margin-bottom:0.5em`

	create Message in Panel
	set the content of Message to `Standalone Codex environment. Click Launch Codex to open the editor and reference manual.`
	set the style of Message to `display:block;line-height:1.5;margin-bottom:0.8em`

	create StartButton in Panel
	set the text of StartButton to `Launch Codex`
	set the style of StartButton to `padding:0.55em 0.9em;border:1px solid #999;border-radius:0.4em;background:#f0f0f0;cursor:pointer`
	on click StartButton gosub to LaunchCodex

	gosub to LaunchCodex
	stop

LaunchCodex:
	if Running return
	set style `display` of Panel to `none`
	rest get Script from `/resources/ecs/codex.ecs?v=` cat now
	run Script as CodexModule
	set Running
	return

	on message
	begin
		put the message into Incoming
		if Incoming is `restore`
		begin
			clear Running
			set style `display` of Panel to `block`
		end
	end
