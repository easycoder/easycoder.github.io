! EC-0009: starts with / ends with string conditions

string S

put `hello world` into S

if S starts with `hello`
begin
    log `starts ok`
end

if S ends with `world`
begin
    log `ends ok`
end

if S starts with `world`
begin
    log `bad starts`
end

if S ends with `hello`
begin
    log `bad ends`
end
